{
  "manifest_version": 2,
  "name": "Search with me",
  "version": "1.3",
  "description": "Search any site with a single right-click. Add your favorite search engines, select text, and go — fast, private, customizable.",
  "permissions": [
    "menus",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "48": "search-with-me.svg",
    "96": "search-with-me.svg"
  },
  "browser_action": {
    "default_icon": "search-with-me.svg",
    "default_title": "Search with me",
    "default_popup": "options.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "drummer@atomicmail.io",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
